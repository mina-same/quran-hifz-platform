{
  "expo": {
    "name": "منصة تحفيظ القرآن",
    "slug": "quran-hifz-mobile",
    "scheme": "quran-hifz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "نحتاج إذن الميكروفون لتسجيل تلاوة الواجب وإرساله للمعلم"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B5E20",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-audio",
        {
          "microphonePermission": "نحتاج إذن الميكروفون لتسجيل تلاوة الواجب وإرساله للمعلم"
        }
      ],
      "expo-secure-store"
    ]
  }
}
