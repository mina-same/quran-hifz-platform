# Public URL of this frontend — used to build absolute Open Graph image URLs for social sharing.
# Production: set to your deployed frontend's root URL, e.g. https://quran.yourdomain.com
# Local dev: leave empty (OG images will use relative paths, which is fine for local testing).
VITE_PUBLIC_URL=

# Base URL the browser uses for API calls.
# Local dev: leave as /api — the Vite dev server proxies it to VITE_API_PROXY_TARGET.
# Production (Vercel): set to your deployed backend's full URL, e.g. https://api.yourdomain.com/api
VITE_API_URL=/api

# Dev-only: backend host the Vite dev server proxies /api requests to. Ignored in production builds.
VITE_API_PROXY_TARGET=http://localhost:5001
